---

<div class="cloud-decoration" aria-hidden="true">
  <!-- Desktop left -->
  <div class="cloud cloud-left">
    <div class="cloud-inner cloud-inner-left">
      <div class="cloud-rotate cloud-rotate-left">
        <div class="cloud-scale cloud-scale-left">
          <svg viewBox="0 0 320 200" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <radialGradient id={`gradL-${uid}`} cx="50%" cy="50%" r="55%">
                <stop offset="0%" stop-color="#e8837c"></stop>
                <stop offset="55%" stop-color="#f4a0b5"></stop>
                <stop offset="100%" stop-color="#ffd1c1"></stop>
              </radialGradient>
              <filter
                id={`filterL-${uid}`}
                x="-10%"
                y="-10%"
                width="120%"
                height="120%"
              >
                <feTurbulence
                  type="fractalNoise"
                  baseFrequency="0.04"
                  numOctaves="4"
                  seed="2"
                  result="noise"></feTurbulence>
                <feDisplacementMap
                  in="SourceGraphic"
                  in2="noise"
                  scale="12"
                  result="displaced"></feDisplacementMap>
                <feGaussianBlur
                  in="displaced"
                  stdDeviation="1.5"
                  result="blurred"></feGaussianBlur>
              </filter>
            </defs>
            <path
              d={leftPath}
              fill={`url(#gradL-${uid})`}
              filter={`url(#filterL-${uid})`}></path>
            <text
              x="160"
              y="88"
              font-family="var(--font-logo), cursive"
              font-size="32"
              fill="#5d3a4a"
              opacity="0.7"
              text-anchor="middle"
              dominant-baseline="central"
            >
              spiro spero
            </text>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Desktop right -->
