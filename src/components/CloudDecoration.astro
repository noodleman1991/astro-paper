<style>
  /* Container: fixed background layer, content scrolls over it */
  .cloud-decoration {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    opacity: 0.55;
  }

  /* Dark mode: reduce opacity */
  :where([data-theme="dark"]) .cloud-decoration {
    opacity: 0.25;
  }

  /* Desktop cloud positioning */
  .cloud-left {
    position: absolute;
    left: 0;
    top: 50%;
    width: 280px;
  }

  .cloud-right {
    position: absolute;
    right: 0;
    top: 50%;
    width: 280px;
  }

  .cloud-mobile {
    position: absolute;
    top: 1rem;
    left: 0.5rem;
    width: 200px;
  }

  /* Responsive show/hide */
  .cloud-left,
  .cloud-right {
    display: none;
  }
  .cloud-mobile {
    display: block;
  }

  @media (min-width: 768px) {
    .cloud-left,
    .cloud-right {
      display: block;
    }
    .cloud-mobile {
      display: none;
    }
  }

  /* Multi-layered animations with coprime durations for natural drift */
  /* Each wrapper level animates one axis only */

  @keyframes cloud-sway-x {
    0%,
    100% {
      transform: translateX(0);
    }
    50% {
      transform: translateX(18px);
    }
  }

  @keyframes cloud-bob-y {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  @keyframes cloud-rotate {
    0%,
    100% {
      transform: rotate(0deg);
    }
    50% {
      transform: rotate(2deg);
    }
  }

  /* Left cloud: sway-x on outer, bob-y on inner, rotate on innermost */
  .cloud-left {
    animation: cloud-sway-x 8s ease-in-out infinite;
  }
  .cloud-inner-left {
    animation: cloud-bob-y 11s ease-in-out infinite;
  }
  .cloud-rotate-left {
    animation: cloud-rotate 15s ease-in-out infinite;
  }

  /* Right cloud: reversed sway, different durations */
  .cloud-right {
    animation: cloud-sway-x 9s ease-in-out infinite reverse;
  }
  .cloud-inner-right {
    animation: cloud-bob-y 13s ease-in-out infinite;
  }
  .cloud-rotate-right {
    animation: cloud-rotate 17s ease-in-out infinite reverse;
  }

  /* Mobile cloud */
  .cloud-mobile {
    animation: cloud-sway-x 10s ease-in-out infinite;
  }
  .cloud-inner-mobile {
    animation: cloud-bob-y 14s ease-in-out infinite;
  }
  .cloud-rotate-mobile {
    animation: cloud-rotate 19s ease-in-out infinite;
  }

  /* Performance */
  .cloud-left,
  .cloud-right,
  .cloud-mobile,
  .cloud-inner-left,
  .cloud-inner-right,
  .cloud-inner-mobile,
  .cloud-rotate-left,
  .cloud-rotate-right,
  .cloud-rotate-mobile {
    will-change: transform;
  }

  /* Accessibility: respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .cloud-left,
    .cloud-right,
    .cloud-mobile,
    .cloud-inner-left,
    .cloud-inner-right,
    .cloud-inner-mobile,
    .cloud-rotate-left,
    .cloud-rotate-right,
    .cloud-rotate-mobile {
      animation: none;
    }
  }

  /* Hide from print */
  @media print {
    .cloud-decoration {
      display: none;
    }
  }
</style>
