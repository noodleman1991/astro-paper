<style>
  /* Container: fixed background layer, content scrolls over it */
  .cloud-decoration {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    opacity: 0.55;
  }

  /* Dark mode: reduce opacity */
  :where([data-theme="dark"]) .cloud-decoration {
    opacity: 0.25;
  }

  /* Desktop cloud positioning */
  .cloud-left {
    position: absolute;
    left: 0;
    top: 50%;
    width: 280px;
  }

  .cloud-right {
    position: absolute;
    right: 0;
    top: 50%;
    width: 280px;
  }

  .cloud-mobile {
    position: absolute;
    top: 5rem;
    left: 0.5rem;
    width: 200px;
  }

  /* Responsive show/hide */
  .cloud-left,
  .cloud-right {
    display: none;
  }
  .cloud-mobile {
    display: block;
  }

  @media (min-width: 768px) {
    .cloud-left,
    .cloud-right {
      display: block;
    }
    .cloud-mobile {
      display: none;
    }
  }

  /* Multi-layered animations with coprime durations for natural drift.
     Asymmetric keyframe percentages make the motion feel wind-driven
     rather than mechanical. 4 layers: sway-x, bob-y, rotate, scale-breathe. */

  @keyframes cloud-sway-x {
    0% {
      transform: translateX(0);
    }
    40% {
      transform: translateX(24px);
    }
    70% {
      transform: translateX(-8px);
    }
    100% {
      transform: translateX(0);
    }
  }

  @keyframes cloud-bob-y {
    0% {
      transform: translateY(0);
    }
    35% {
      transform: translateY(-16px);
    }
    65% {
      transform: translateY(6px);
    }
    100% {
      transform: translateY(0);
    }
  }

  @keyframes cloud-rotate {
    0% {
      transform: rotate(0deg);
    }
    30% {
      transform: rotate(2.5deg);
    }
    60% {
      transform: rotate(-1.5deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }

  @keyframes cloud-breathe {
    0% {
      transform: scale(1);
    }
    45% {
      transform: scale(1.04);
    }
    80% {
      transform: scale(0.97);
    }
    100% {
      transform: scale(1);
    }
  }

  /* Left cloud: 4 nested layers, each animates one axis */
  .cloud-left {
    animation: cloud-sway-x 8s ease-in-out infinite;
  }
  .cloud-inner-left {
    animation: cloud-bob-y 11s ease-in-out infinite;
  }
  .cloud-rotate-left {
    animation: cloud-rotate 15s ease-in-out infinite;
  }
  .cloud-scale-left {
    animation: cloud-breathe 19s ease-in-out infinite;
  }

  /* Right cloud: different durations + reversed directions */
  .cloud-right {
    animation: cloud-sway-x 9s ease-in-out infinite reverse;
  }
  .cloud-inner-right {
    animation: cloud-bob-y 13s ease-in-out infinite;
  }
  .cloud-rotate-right {
    animation: cloud-rotate 17s ease-in-out infinite reverse;
  }
  .cloud-scale-right {
    animation: cloud-breathe 23s ease-in-out infinite;
  }

  /* Mobile cloud: gentler motion */
  .cloud-mobile {
    animation: cloud-sway-x 12s ease-in-out infinite;
  }
  .cloud-inner-mobile {
    animation: cloud-bob-y 16s ease-in-out infinite;
  }
  .cloud-rotate-mobile {
    animation: cloud-rotate 21s ease-in-out infinite;
  }

  /* Performance */
  .cloud-left,
  .cloud-right,
  .cloud-mobile,
  .cloud-inner-left,
  .cloud-inner-right,
  .cloud-inner-mobile,
  .cloud-rotate-left,
  .cloud-rotate-right,
  .cloud-rotate-mobile,
  .cloud-scale-left,
  .cloud-scale-right {
    will-change: transform;
  }

  /* Accessibility: respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .cloud-left,
    .cloud-right,
    .cloud-mobile,
    .cloud-inner-left,
    .cloud-inner-right,
    .cloud-inner-mobile,
    .cloud-rotate-left,
    .cloud-rotate-right,
    .cloud-rotate-mobile,
    .cloud-scale-left,
    .cloud-scale-right {
      animation: none;
      will-change: auto;
    }
  }

  /* Hide from print */
  @media print {
    .cloud-decoration {
      display: none;
    }
  }
</style>
